# ── 服務端點 ─────────────────────────────────────────────────
EMBED_URL=http://localhost:8000
RERANK_URL=http://localhost:8002

# ── 伺服器設定 ───────────────────────────────────────────────
APP_PORT=3000
CONCURRENCY=2
TIMEOUT_MS=30000
MAX_RETRIES=2

# ── RAM 管理 ─────────────────────────────────────────────────
# Embedding 每次最多處理幾筆（大批量自動分塊）
MAX_BATCH_SIZE=64
# Rerank 每次最多接收幾篇文件
MAX_DOCUMENTS=1024

# ── Model 名稱（用於 API 回應，不影響推論） ──────────────────
DEFAULT_EMBED_MODEL=bge-m3
DEFAULT_RERANK_MODEL=bge-reranker-v2-m3
