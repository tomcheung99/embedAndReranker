# ── 服務端點 ─────────────────────────────────────────────────
EMBED_URL=http://localhost:8000
RETRIEVE_URL=http://localhost:8100
COLBERT_URL=http://localhost:8001
RERANK_URL=http://localhost:8002

# ── 伺服器設定 ───────────────────────────────────────────────
PORT=3999
CONCURRENCY=2
